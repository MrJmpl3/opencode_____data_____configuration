{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "composite": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/solid",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": ["./**/*.ts", "./**/*.tsx"]
}
