{
  "$schema": "https://opencode.ai/tui.json",
  "plugin": [
    [
      "./plugins-tui/limits",
      {
        "compact": true,
      },
    ],
    [
      "./plugins-tui/quota",
      {
        "compact": false,
        "displayMode": "used",
        "visibleProviders": ["openai"],
      },
    ],
    [
      "./plugins-tui/cache",
      {
        "compact": true,
      },
    ],
    "opencode-quotes-plugin",
  ],
  "theme": "opencode",
}
