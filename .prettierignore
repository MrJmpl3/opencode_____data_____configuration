# Prettier debe formatear fuente humana, no metadatos internos de Git ni dependencias instaladas.
.git/
node_modules/
plugins/**/node_modules/
plugins-tui/**/node_modules/

# En esta configuracion personal, los manifests y locks locales son artefactos regenerables por plugin.
package.json
package-lock.json
npm-shrinkwrap.json
pnpm-lock.yaml
yarn.lock
bun.lock
bun.lockb

# Las salidas generadas se reconstruyen desde el codigo fuente y no necesitan estabilidad de formato manual.
dist/
build/
coverage/
.nyc_output/

# Las caches aceleran herramientas locales, pero suelen contener rutas absolutas o formatos internos no editables.
.cache/
.turbo/
.vite/
*.tsbuildinfo

# El estado de OpenCode y las tareas locales documentan una sesion, no una convencion de formato del proyecto.
.omo/
tasks/

# Registros y variables de entorno quedan fuera para evitar reformatear diagnosticos o secretos locales.
*.log
.env
.env.*
!.env.example
!.env.sample
