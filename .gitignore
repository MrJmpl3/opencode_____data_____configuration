# OpenCode genera estado operacional local; versionarlo mezclaria historial del proyecto con sesiones temporales.
.omo/
tasks/

# Las dependencias instaladas son artefactos reproducibles y pesados; Git debe conservar fuentes, no vendors locales.
node_modules/
# En esta configuracion personal, los manifests y locks nacen de instalaciones por plugin y no son contrato compartido.

# Las salidas derivadas deben regenerarse en cada entorno para evitar binarios o caches obsoletos en el historial.
dist/
build/
coverage/
.nyc_output/
.cache/
.turbo/
.vite/
# TypeScript serializa estado incremental en *.tsbuildinfo; compartirlo acoplaria el repo a rutas y versiones locales.
*.tsbuildinfo

# Los registros son diagnostico efimero y pueden filtrar rutas, tokens parciales o respuestas de proveedores.
*.log
# Cada gestor de paquetes usa nombres de log propios; los comodines cubren rotaciones y sufijos automaticos.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*

# Los archivos .env son frontera de secretos; solo las plantillas documentan variables sin exponer valores reales.
.env
.env.*
# El prefijo ! revierte una regla previa y permite versionar ejemplos seguros como contrato de configuracion.
!.env.example
!.env.sample

# Archivos de editor y sistema operativo describen preferencias locales, no requisitos para ejecutar el proyecto.
.DS_Store
Thumbs.db
.idea/
.vscode/

# Este .gitignore tambien es local; una regla que el equipo deba heredar pertenece a un ignore versionado.
.gitignore
# Los plugins TUI son paquetes reutilizables; sus .gitignore locales documentan reglas que si pertenecen a cada paquete.
!tui-plugins/*/.gitignore

# Git aplica patrones por orden, usa barras finales para directorios y permite auditar decisiones con git check-ignore -v.
# Local AI runtime state
.atl/
go-workspaces.json
