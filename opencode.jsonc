{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": true,
    "mcp": {
        "context7": {
            "enabled": true,
            "headers": {
                "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
            },
            "type": "remote",
            "url": "https://mcp.context7.com/mcp"
        },
        "gh_grep": {
            "enabled": true,
            "type": "remote",
            "url": "https://mcp.grep.app"
        },
        "github": {
            "enabled": true,
            "headers": {
                "Authorization": "Bearer {env:COMPOSER_AUTH_TOKEN}"
            },
            "type": "remote",
            "url": "https://api.githubcopilot.com/mcp"
        },
        "nuxt": {
            "enabled": true,
            "type": "remote",
            "url": "https://nuxt.com/mcp"
        }
    },
    "permission": {
        "bash": {
            "./vendor/bin/pest *": "allow",
            "./vendor/bin/php-cs-fixer *": "allow",
            "./vendor/bin/phpstan *": "allow",
            "*": "ask",
            "basename *": "allow",
            "cat *": "allow",
            "cd *": "allow",
            "chmod *": "allow",
            "cmp *": "allow",
            "column *": "allow",
            "Compare-*": "allow",
            "composer *": "allow",
            "cut *": "allow",
            "date *": "allow",
            "df *": "allow",
            "dirname *": "allow",
            "du *": "allow",
            "echo *": "allow",
            "file *": "allow",
            "find *": "allow",
            "findstr *": "allow",
            "Format-*": "allow",
            "Get-ChildItem *": "allow",
            "Get-Content *": "allow",
            "Get-Date *": "allow",
            "Get-Location *": "allow",
            "Get-Random *": "allow",
            "git add *": "allow",
            "git branch *": "allow",
            "git checkout *": "allow",
            "git commit *": "allow",
            "git diff *": "allow",
            "git grep *": "allow",
            "git log *": "allow",
            "git push *": "ask",
            "git show *": "allow",
            "git status *": "allow",
            "grep *": "allow",
            "head *": "allow",
            "Join-Path *": "allow",
            "ls *": "allow",
            "Measure-*": "allow",
            "mkdir *": "allow",
            "npm *": "allow",
            "php *": "allow",
            "php artisan *": "allow",
            "pwd": "allow",
            "readlink *": "allow",
            "realpath *": "allow",
            "rm *": "ask",
            "sed *": "allow",
            "Select-*": "allow",
            "sleep *": "allow",
            "sort *": "allow",
            "Sort-*": "allow",
            "Split-Path *": "allow",
            "Start-Sleep *": "allow",
            "stat *": "allow",
            "tail *": "allow",
            "tr *": "allow",
            "tree *": "allow",
            "uniq *": "allow",
            "wc *": "allow",
            "Where-Object *": "allow",
            "which *": "allow",
            "Write-Host *": "allow",
            "Write-Output *": "allow"
        },
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.env.example": "allow"
        }
    },
    "plugin": [
        "@gotgenes/opencode-agent-identity@latest",
        "@slkiser/opencode-quota@latest",
        "@tarquinen/opencode-dcp@latest"
    ],
    "provider": {
        "github-copilot": {
            "options": {
                "chunkTimeout": 6000000,
                "timeout": 12000000,
                "setCacheKey": true
            }
        },
        "openai": {
            "options": {
                "chunkTimeout": 6000000,
                "setCacheKey": true,
                "timeout": 12000000
            }
        },
        "opencode": {
            "options": {
                "chunkTimeout": 6000000,
                "timeout": 12000000
            }
        },
        "opencode-go": {
            "options": {
                "chunkTimeout": 6000000,
                "timeout": 12000000,
                "setCacheKey": true
            }
        },
        "openrouter": {
            "options": {
                "chunkTimeout": 6000000,
                "setCacheKey": true,
                "timeout": 12000000
            }
        }
    }
}