{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "bash-language-server": {
      "command": ["bash-language-server", "start"],
      "extensions": [".sh", ".bash", ".zsh"],
    },
    "intelephense": {
      "command": ["intelephense", "--stdio"],
      "extensions": [".php", ".phtml"],
    },
    "typescript-language-server": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs"],
    },
    "vscode-eslint-language-server": {
      "command": ["vscode-eslint-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs", ".vue"],
    },
    "vue-language-server": {
      "command": ["vue-language-server", "--stdio"],
      "extensions": [".vue"],
    },
    "vscode-css-language-server": {
      "command": ["vscode-css-language-server", "--stdio"],
      "extensions": [".css", ".scss", ".less"],
    },
    "tailwindcss-language-server": {
      "command": ["tailwindcss-language-server", "--stdio"],
      "extensions": [
        ".css",
        ".scss",
        ".less",
        ".html",
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".vue",
        ".md",
        ".php",
      ],
    },
    "vscode-html-language-server": {
      "command": ["vscode-html-language-server", "--stdio"],
      "extensions": [".html", ".htm"],
    },
    "vscode-json-language-server": {
      "command": ["vscode-json-language-server", "--stdio"],
      "extensions": [".json", ".jsonc"],
    },
    "marksman": {
      "command": ["marksman"],
      "extensions": [".md"],
    },
    "taplo": {
      "command": ["taplo", "lsp", "stdio"],
      "extensions": [".toml"],
    },
    "yaml-language-server": {
      "command": ["yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"],
    },
  },
  // Los servidores MCP se declaran globalmente aqui.
  // El acceso por rol a esos MCPs lo define `oh-my-opencode-slim.json`.
  "mcp": {
    // La busqueda estructural se declara globalmente, pero el acceso intensivo a MCPs se
    // enruta intencionalmente a traves del preset activo. En el preset `openai` actual,
    // los roles no orquestadores delegan cuando necesitan capacidades exclusivas de MCP.
    "ast_grep": {
      "enabled": true,
      "type": "local",
      "command": ["ast-grep-mcp"],
      "timeout": 30000,
    },
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
    // Busqueda publica de codigo en GitHub para ejemplos reales. En el preset actual
    // se enruta via `@librarian`.
    "grep_app": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app",
    },
    "deepwiki": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp",
    },
    "github": {
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:COMPOSER_AUTH_TOKEN}",
      },
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
    },
    "nuxt": {
      "enabled": true,
      "type": "remote",
      "url": "https://nuxt.com/mcp",
    },
  },
  "provider": {
    "openai": {
      "options": {
        "setCacheKey": true,
      },
      "models": {
        "gpt-5.5": {
          "limit": {
            "context": 272000,
            "input": 272000,
            "output": 128000,
          },
        },
        "gpt-5.5-fast": {
          "limit": {
            "context": 272000,
            "input": 272000,
            "output": 128000,
          },
        },
        "gpt-5.5-pro": {
          "limit": {
            "context": 272000,
            "input": 272000,
            "output": 128000,
          },
        },
      },
    },
  },
  "agent": {
    "orchestrator": {
      "color": "#3B82F6",
    },
    "oracle": {
      "color": "#F59E0B",
    },
    "librarian": {
      "color": "#06B6D4",
    },
    "explorer": {
      "color": "#10B981",
    },
    "designer": {
      "color": "#8B5CF6",
    },
    "fixer": {
      "color": "#EF4444",
    },
    // Los roles genericos integrados siguen deshabilitados porque el setup activo usa
    // el conjunto de roles de `oh-my-opencode-slim`.
    "explore": {
      "disable": true,
    },
    "general": {
      "disable": true,
    },
  },
  "plugin": ["oh-my-opencode-slim"],
}
