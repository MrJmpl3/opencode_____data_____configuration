{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
    },
    "gh_grep": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app",
    },
    "github": {
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:COMPOSER_AUTH_TOKEN}",
      },
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
    },
    "nuxt": {
      "enabled": true,
      "type": "remote",
      "url": "https://nuxt.com/mcp",
    },
  },
  "provider": {
    "openai": {
      "options": {
        "setCacheKey": true,
      },
    },
  },
}