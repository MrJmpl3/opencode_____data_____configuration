root = true

# Reglas globales
# UTF-8, LF, y newline final evitan diffs espurios entre editores.
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# JavaScript / TypeScript
# 2 espacios mantienen bloques compactos en JSX/TSX anidado.
[*.{js,jsx,mjs,cjs,ts,tsx,mts,cts}]
indent_style = space
indent_size = 2

# CSS / Sass / Less
[*.{css,scss,sass,less}]
indent_style = space
indent_size = 2

# JSON / YAML
[*.{json,jsonc,json5,yml,yaml}]
indent_style = space
indent_size = 2

# Markdown
# Espacios finales son parte de la sintaxis de salto de línea manual.
[*.{md,mdx,markdown}]
trim_trailing_whitespace = false
max_line_length = off

# PHP / Python / C#
[*.{php,py,cs}]
indent_style = space
indent_size = 4

# Rust
[*.rs]
indent_style = space
indent_size = 4

# Java / Kotlin
[*.{java,kt,kts}]
indent_style = space
indent_size = 4

# Go
# `gofmt` usa tabs; el ancho se define en el editor, no acá.
[*.go]
indent_style = tab

# Shell
[*.{sh,bash,zsh,fish}]
indent_style = space
indent_size = 2
shell_variant = bash

# Makefiles
# El tab inicial es parte de la sintaxis de Make.
[Makefile,makefile,GNUmakefile]
indent_style = tab

# Docker
[Dockerfile,Dockerfile.*]
indent_style = space
indent_size = 2

# TOML / INI / CFG
[*.{toml,ini,cfg,conf}]
indent_style = space
indent_size = 2

# SQL
[*.sql]
indent_style = space
indent_size = 2

# Git
[.gitignore,.gitattributes,.gitmodules]
indent_style = space
indent_size = 2

# Parches y diffs
# Espacios finales y saltos de línea son parte de la evidencia.
[*.{diff,patch}]
trim_trailing_whitespace = false
insert_final_newline = false

# EditorConfig
[.editorconfig]
indent_style = space
indent_size = 2
