{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "atlas": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini-fast"
    },
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "librarian": {
      "model": "openai/gpt-5.4-mini-fast"
    },
    "metis": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "multimodal-looker": {
      "fallback_models": [
        {
          "model": "openai/gpt-5-nano"
        }
      ],
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "prometheus": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "sisyphus": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    }
  },
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  "categories": {
    "artistry": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "quick": {
      "model": "openai/gpt-5.4-mini"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "visual-engineering": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "writing": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    }
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true
  },
  "hashline_edit": true,
  "sisyphus": {
    "tasks": {
      "claude_code_compat": false
    }
  }
}
