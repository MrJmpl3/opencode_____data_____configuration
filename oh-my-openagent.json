{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "atlas": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini"
    },
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "librarian": {
      "model": "openai/gpt-5.4-mini"
    },
    "metis": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "multimodal-looker": {
      "fallback_models": [
        {
          "model": "openai/gpt-5-nano"
        }
      ],
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "prometheus": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "sisyphus": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    }
  },
  "auto_update": true,
  "background_task": {
    "defaultConcurrency": 8,
    "providerConcurrency": {
      "anthropic": 5,
      "github-copilot": 10,
      "google": 10,
      "openai": 5,
      "opencode": 15,
      "openrouter": 20
    }
  },
  "categories": {
    "artistry": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "quick": {
      "model": "openai/gpt-5.4-mini"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "visual-engineering": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "writing": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    }
  },
  "hashline_edit": true,
  "model_capabilities": {
    "auto_refresh_on_start": true,
    "enabled": true
  },
  "sisyphus": {
    "tasks": {
      "claude_code_compat": false,
      "storage_path": ".sisyphus/tasks"
    }
  },
  "sisyphus_agent": {
    "planner_enabled": true,
    "replace_plan": true
  }
}