{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "atlas": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini",
      "variant": "xhigh"
    },
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "permission": {
        "bash": {
          "git": "allow",
          "test": "allow"
        },
        "edit": "allow"
      },
      "prompt_append": "You are the primary implementation agent. Own the codebase. Explore, decide, execute. Use LSP and AST-grep aggressively.",
      "variant": "xhigh"
    },
    "librarian": {
      "model": "openai/gpt-5.4-mini",
      "variant": "xhigh"
    },
    "metis": {
      "model": "openai/gpt-5.4-mini",
      "variant": "xhigh"
    },
    "momus": {
      "model": "openai/gpt-5.5",
      "prompt_append": "Focus on code quality, edge cases, and test coverage.",
      "variant": "xhigh"
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "oracle": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "prometheus": {
      "model": "openai/gpt-5.4-mini",
      "prompt_append": "Keep plans concise. Focus on file structure and key decisions.",
      "variant": "xhigh"
    },
    "sisyphus": {
      "model": "openai/gpt-5.5",
      "prompt_append": "Delegate heavily to hephaestus for implementation. Parallelize exploration.",
      "variant": "xhigh"
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.4-mini",
      "variant": "xhigh"
    }
  },
  "background_task": {
    "defaultConcurrency": 8,
    "providerConcurrency": {
      "openai": 5
    }
  },
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  "categories": {
    "artistry": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "quick": {
      "model": "openai/gpt-5.4-mini"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "visual-engineering": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "writing": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    }
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true
  },
  "hashline_edit": true
}
