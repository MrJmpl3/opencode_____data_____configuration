{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "atlas": {
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "openrouter/minimax/minimax-m2.7"
      ],
      "model": "opencode-go/minimax-m2.7",
      "variant": "medium"
    },
    "explore": {
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "openrouter/minimax/minimax-m2.7"
      ],
      "model": "opencode-go/minimax-m2.7",
      "variant": "low"
    },
    "librarian": {
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "openrouter/minimax/minimax-m2.7"
      ],
      "model": "opencode-go/minimax-m2.7",
      "variant": "low"
    },
    "metis": {
      "fallback_models": [
        "opencode-go/deepseek-v4-pro",
        "opencode-go/deepseek-v4-flash",
        "openrouter/kimi/kimi-k2.6"
      ],
      "model": "opencode-go/kimi-k2.6",
      "variant": "high"
    },
    "momus": {
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "openrouter/deepseek/deepseek-v4-pro"
      ],
      "model": "opencode-go/deepseek-v4-pro",
      "prompt_append": "Focus on code quality, edge cases, and test coverage.",
      "variant": "high"
    },
    "multimodal-looker": {
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "openrouter/kimi/kimi-k2.6"
      ],
      "model": "opencode-go/kimi-k2.6",
      "variant": "medium"
    },
    "oracle": {
      "fallback_models": [
        "opencode-go/deepseek-v4-pro",
        "opencode-go/deepseek-v4-flash",
        "openrouter/kimi/kimi-k2.6"
      ],
      "model": "opencode-go/kimi-k2.6",
      "variant": "high"
    },
    "prometheus": {
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "openrouter/kimi/kimi-k2.6"
      ],
      "model": "opencode-go/kimi-k2.6",
      "prompt_append": "Always interview first. Validate scope before planning.",
      "variant": "high"
    },
    "sisyphus": {
      "fallback_models": [
        "opencode-go/minimax-m2.7",
        "openrouter/deepseek/deepseek-v4-flash"
      ],
      "model": "opencode-go/deepseek-v4-flash",
      "prompt_append": "Delegate implementation to deep/unspecified-high agents. Parallelize exploration via explore/librarian.",
      "ultrawork": {
        "model": "opencode-go/kimi-k2.6",
        "variant": "max"
      },
      "variant": "max"
    },
    "sisyphus-junior": {
      "fallback_models": ["openrouter/deepseek/deepseek-v4-flash"],
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "medium"
    }
  },
  "background_task": {
    "defaultConcurrency": 5,
    "modelConcurrency": {
      "opencode-go/deepseek-v4-flash": 10,
      "opencode-go/deepseek-v4-pro": 2,
      "opencode-go/kimi-k2.6": 3,
      "opencode-go/minimax-m2.7": 8,
      "openrouter/deepseek/deepseek-v4-flash": 5,
      "openrouter/deepseek/deepseek-v4-pro": 2,
      "openrouter/kimi/kimi-k2.6": 2,
      "openrouter/minimax/minimax-m2.7": 5
    },
    "providerConcurrency": {
      "opencode-go": 8,
      "openrouter": 5
    }
  },
  "categories": {
    "artistry": {
      "description": "Soluciones creativas no convencionales, enfoques alternativos",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "openrouter/kimi/kimi-k2.6"
      ],
      "model": "opencode-go/kimi-k2.6",
      "variant": "high"
    },
    "deep": {
      "description": "Resolucion autonoma: investiga a fondo antes de actuar",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "openrouter/deepseek/deepseek-v4-pro"
      ],
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "high"
    },
    "quick": {
      "description": "Tareas triviales: typo, un archivo, cambio simple",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "openrouter/minimax/minimax-m2.7"
      ],
      "model": "opencode-go/minimax-m2.7",
      "variant": "low"
    },
    "ultrabrain": {
      "description": "Razonamiento logico profundo, algoritmos, arquitectura",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "openrouter/deepseek/deepseek-v4-pro"
      ],
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "max"
    },
    "unspecified-high": {
      "description": "Tareas generales de alto esfuerzo o complejidad",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "openrouter/deepseek/deepseek-v4-pro"
      ],
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "high"
    },
    "unspecified-low": {
      "description": "Tareas generales de esfuerzo bajo a moderado",
      "fallback_models": ["openrouter/deepseek/deepseek-v4-flash"],
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high"
    },
    "visual-engineering": {
      "description": "Frontend, UI/UX, diseno, animacion, CSS/styling",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "openrouter/kimi/kimi-k2.6"
      ],
      "model": "opencode-go/kimi-k2.6",
      "variant": "medium"
    },
    "writing": {
      "description": "Documentacion, prosa, escritura tecnica",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "openrouter/minimax/minimax-m2.7"
      ],
      "model": "opencode-go/minimax-m2.7",
      "variant": "medium"
    }
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true
  },
  "hashline_edit": true,
  "model_capabilities": {
    "auto_refresh_on_start": true,
    "enabled": true
  },
  "runtime_fallback": {
    "cooldown_seconds": 30,
    "enabled": true,
    "notify_on_fallback": true,
    "timeout_seconds": 15
  },
  "sisyphus_agent": {
    "planner_enabled": true,
    "replace_plan": true
  }
}
